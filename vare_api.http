# ============================================================
# VARE — Voice Authenticity Risk Engine
# API Integration Reference
# ============================================================
# Tool     : VS Code REST Client extension (humao.rest-client)
# Install  : Extensions → search "REST Client" → Install
# Usage    : Click "Send Request" above any ### block
#
# Base URL : Change @baseUrl below to match your deployment
# Local    : http://127.0.0.1:8001
# ============================================================

@baseUrl = http://127.0.0.1:8001

# ============================================================
# ENDPOINT 1 — Health Check
# Use this to verify the server is running and all models
# are loaded before sending audio for analysis.
# ============================================================

### Health Check
GET {{baseUrl}}/health
Accept: application/json

# Response:
# HTTP/1.1 200 OK
#
# {
#   "device": "cpu",
#   "models_loaded": {
#     "aasist3": true,
#     "wav2vec2": true,
#     "rawnet2": true
#   }
# }
#
# Integration note:
#   Check all three values are true before sending audio.
#   If any model is false, results will still be returned
#   but ensemble accuracy will be lower.


# ============================================================
# ENDPOINT 2 — Analyze Audio
#
# Method  : POST /analyze
# Body    : multipart/form-data, field name = "file"
# Formats : .wav  .mp3  .flac  .ogg  .m4a  .webm
# Min len : 2 seconds
# Max len : no limit (auto-segmented into 4s windows)
#
# Change the file path on the line starting with "<" below.
# ============================================================

### Analyze Audio
POST {{baseUrl}}/analyze
Content-Type: multipart/form-data; boundary=VareBoundary

--VareBoundary
Content-Disposition: form-data; name="file"; filename="audio.wav"
Content-Type: audio/wav

< C:/path/to/your/audio.wav
--VareBoundary--


# ============================================================
# RESPONSE SCHEMA
# ============================================================
#
# {
#   "status":           "ok" | "error",
#   "filename":         string,
#   "duration_sec":     float,
#   "n_segments":       int,          // number of 4s windows analysed
#   "ensemble_score":   float,        // 0–100, PRIMARY field for integration
#   "risk_level":       "LOW" | "MEDIUM" | "HIGH",
#   "risk_color":       "#22c55e" | "#f59e0b" | "#ef4444",
#   "model_confidence": float,        // 0–1, agreement between models
#   "models": {
#     "aasist3": {
#       "available":            bool,
#       "error":                string | null,
#       "aggregate_spoof_prob": float | null,   // 0–100
#       "verdict":              "AI Generated" | "Genuine" | null,
#       "segment_scores":       float[]         // per 4s window
#     },
#     "wav2vec2":  { ...same fields... },
#     "rawnet2":   { ...same fields... }
#   }
# }


